# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_key_here        # Claude API — script generation (Haiku model)
PEXELS_API_KEY=your_key_here          # Pexels — stock scene images (free tier works)
FREESOUND_API_KEY=your_key_here       # Freesound — background music tracks (free tier works)

# ── Required for YouTube publishing ───────────────────────────────────────────
# Drop google_client_secret.json into credentials/ folder — no env var needed.
# OAuth refresh token is stored automatically after first Google login per channel.

# ── Required for TikTok publishing ────────────────────────────────────────────
# Drop {slug}_tiktok_cookies.txt into credentials/ folder — no env var needed.
# Export cookies from a logged-in TikTok session (EditThisCookie or similar).

# ── Optional upgrades ─────────────────────────────────────────────────────────
# ELEVENLABS_API_KEY=...       # Better TTS quality ($5/month) — upgrade from Kokoro
# REPLICATE_API_TOKEN=...      # Better image quality ($0.003/img) — upgrade from Pexels
